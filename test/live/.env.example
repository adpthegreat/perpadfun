# test/live/.env.example
#
# Copy this file to test/live/.env (gitignored), fill in LIVE_TEST_PRIVATE_KEY
# and LIVE_TEST_RPC_URL, then run the live suite:
#
#   IMPERIAL_LIVE_TESTS=1 bunx vitest run test/live/
#
# These tests SPEND REAL FUNDS on Imperial mainnet. Per-test cost: ~$0.20–$0.40.
# Full suite cost: ~$2. The wallet you use here must be:
#   1. NOT the production keeper treasury wallet (use a dedicated test wallet)
#   2. Registered on Imperial (sign in via the Imperial frontend once)
#   3. Funded with ~$50 USDC + ~0.05 SOL on mainnet for the full suite
#
# To generate a dedicated wallet:
#   solana-keygen new -o test-wallet.json --no-bip39-passphrase
#   solana-keygen pubkey test-wallet.json    # send funds here
#   # then paste the JSON content of test-wallet.json into LIVE_TEST_PRIVATE_KEY
#
# DO NOT commit test/live/.env. The .gitignore already excludes it; double-check
# before pushing.

# Opt-in flag. Tests are SKIPPED unless this is exactly "1".
IMPERIAL_LIVE_TESTS=1

# DEDICATED test wallet private key. Accepts EITHER:
#   - JSON byte array: [12,34,56,...,89]
#   - base58 string: 5Jf8nC2gXr...
# DO NOT use the production keeper treasury (TREASURY_SOLANA_PRIVATE_KEY).
LIVE_TEST_PRIVATE_KEY=

# Mainnet RPC URL. Use your own (Helius / QuickNode / etc.) — the public
# endpoint is rate-limited and may cause flaky tests.
LIVE_TEST_RPC_URL=

# Imperial API base URL. Defaults to mainnet; override only if Imperial gives
# you a staging URL.
IMPERIAL_BASE_URL=https://api.imperial.space/api/v1

# Optional: Imperial API key, if your wallet's profile requires one. Most
# wallets DON'T need this — try with it blank first.
IMPERIAL_API_KEY=

# Sizing knobs. Defaults are safe; raise only if you need larger fills for
# accurate slippage measurement on partial closes.
LIVE_TEST_COLLATERAL_USD=10
LIVE_TEST_LEVERAGE=2

# Optional: pin a specific Imperial profile index instead of letting
# pickProfile() choose. Set to 0 if your wallet has only one profile.
# LIVE_TEST_PROFILE_INDEX=0
