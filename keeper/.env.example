# Copy to .env for local dev. In production these are set via `fly secrets set`.

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TREASURY_SOLANA_PRIVATE_KEY=          # base58 OR JSON array of 64 ints

# perpad backend
PERPAD_BASE_URL=https://perpspad.xyz
KEEPER_SECRET=                        # same string saved in Lovable

# Loop cadence
LOOP_INTERVAL_MS=60000

# Risk
MAX_LEVERAGE=2
SKIM_RATIO=0.01           # 1% of buy volume skimmed
COLLATERAL_SPLIT=0.5      # 50% of skim → Drift collateral, 50% → buyback float
MIN_DEPOSIT_USDC=5        # don't push <$5 deposits
MIN_WITHDRAW_USDC=10      # don't pull <$10 withdrawals

# --- Imperial Exchange (routing layer; OFF by default in Phase 0) ---
# Master kill switch. Until this is true the loop never calls Imperial.
IMPERIAL_ENABLED=false
IMPERIAL_BASE_URL=https://api.imperial.space/api/v1
# Optional. Leave blank unless Imperial issues you a production API key.
IMPERIAL_API_KEY=
# off    -> no Imperial traffic at all
# shadow -> log Imperial quotes alongside Jupiter, no orders
# live   -> route orders through Imperial
IMPERIAL_ROUTING_MODE=off
# off       -> never open/close on Imperial
# open-only -> open new positions on Imperial; leave existing Jupiter alone
# full      -> open on Imperial AND force-close existing Jupiter positions
IMPERIAL_POSITION_MODE=off
# off    -> never deposit fees into Imperial profiles
# shadow -> log what WOULD be deposited (no on-chain action)
# live   -> sign + submit /deposit/build-tx (auto-swaps SOL->USDC if needed)
IMPERIAL_DEPOSIT_MODE=off

# =============================================================================
# LOCAL TEST OVERRIDES (uncomment when running locally; DO NOT set on Fly)
# =============================================================================
# Stop the local keeper from racing the Fly keeper on Jupiter perps.
# 'off' = no opens/topups/closes; 'simulate' = build+sim only; 'live' = real.
# PERP_HEDGE_MODE=off
#
# Lower fee gates so a legacy token (e.g. STONKS at ~$90 fees) can trigger
# an Imperial deposit without waiting for production thresholds.
# Production defaults are FEE_GATE_USD=100, TOPUP_FEE_GATE_USD=250,
# OPEN_COLLATERAL_USD=100, TOPUP_COLLATERAL_USD=100.
# FEE_GATE_USD=50
# OPEN_COLLATERAL_USD=50
# TOPUP_FEE_GATE_USD=50
# TOPUP_COLLATERAL_USD=50
#
# Flip Imperial on for the deposit smoke test.
# IMPERIAL_ENABLED=true
# IMPERIAL_API_KEY=<your imperial api key jwt>
# IMPERIAL_DEPOSIT_MODE=live
